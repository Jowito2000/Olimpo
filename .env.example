# URL pública del sitio (sin barra final) — usada en sitemap.xml y robots.txt
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# Email — dirección que recibe los mensajes del formulario de contacto
CONTACT_EMAIL=tu@email.com

# Resend — API key para envío de emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — URL y clave pública del proyecto (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — URLs de conexión a la base de datos (PostgreSQL)
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
