generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CharacterCategory {
  primordial
  titan
  olimpico
  heroe
  mortal
  ninfa
  monstruo
}

enum Gender {
  male
  female
  unknown
}

enum GlossaryCategory {
  concepto
  autor
  lugar
  tribu
  criatura
  objeto
}

enum TimelineCategory {
  origen
  titanomaquia
  dioses
  heroes
  troya
}

enum GraphNodeType {
  individuo
  grupo
  union
}

enum GraphEdgeType {
  partner
  child
  membership
}

// ─── Characters ───────────────────────────────────────────────────────────────

model Character {
  id          String            @id
  name        String
  greekName   String
  category    CharacterCategory
  gender      Gender
  title       String
  description String            @db.Text

  versions          CharacterVersion[]
  treeMemberships   CharacterTree[]
  parentRelations   CharacterRelation[] @relation("ParentRelation")
  childRelations    CharacterRelation[] @relation("ChildRelation")
  partnerRelationsA CharacterPartner[]  @relation("PartnerA")
  partnerRelationsB CharacterPartner[]  @relation("PartnerB")
}

model CharacterVersion {
  id          Int       @id @default(autoincrement())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  source      String
  text        String    @db.Text
  order       Int       @default(0)
}

/// Relación padre → hijo entre personajes
model CharacterRelation {
  id       Int       @id @default(autoincrement())
  parentId String
  childId  String
  parent   Character @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)
  child    Character @relation("ChildRelation", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}

/// Relación de pareja entre personajes (bidireccional, sin duplicados)
model CharacterPartner {
  id           Int       @id @default(autoincrement())
  characterAId String
  characterBId String
  characterA   Character @relation("PartnerA", fields: [characterAId], references: [id], onDelete: Cascade)
  characterB   Character @relation("PartnerB", fields: [characterBId], references: [id], onDelete: Cascade)

  @@unique([characterAId, characterBId])
}

// ─── Trees ────────────────────────────────────────────────────────────────────

model Tree {
  id          String @id
  name        String
  description String
  rootId      String

  memberships CharacterTree[]
  nodes       GraphNode[]
  edges       GraphEdge[]
}

/// Tabla de unión: qué personajes aparecen en qué árbol
model CharacterTree {
  characterId String
  treeId      String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  tree        Tree      @relation(fields: [treeId], references: [id], onDelete: Cascade)

  @@id([characterId, treeId])
}

/// Nodo del grafo genealógico (puede ser individuo, grupo o unión)
model GraphNode {
  id       String            @id @default(cuid())
  treeId   String
  tree     Tree              @relation(fields: [treeId], references: [id], onDelete: Cascade)
  nodeId   String
  type     GraphNodeType
  label    String?
  category CharacterCategory?
  gender   Gender?

  @@unique([treeId, nodeId])
}

/// Arista del grafo genealógico
model GraphEdge {
  id     Int           @id @default(autoincrement())
  treeId String
  tree   Tree          @relation(fields: [treeId], references: [id], onDelete: Cascade)
  source String
  target String
  type   GraphEdgeType

  @@unique([treeId, source, target, type])
}

// ─── Glossary & Timeline ──────────────────────────────────────────────────────

model GlossaryTerm {
  id          String           @id
  title       String
  description String           @db.Text
  category    GlossaryCategory
}

model TimelineEvent {
  id          String           @id
  period      String
  title       String
  description String           @db.Text
  category    TimelineCategory
  level       Int
  order       Int              @default(0)
}
